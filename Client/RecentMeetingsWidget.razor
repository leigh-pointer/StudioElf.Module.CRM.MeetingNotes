@namespace StudioElf.Module.CRM.Extensions
@using StudioElf.Module.CRM
@using StudioElf.Module.CRM.MeetingNotes.Models
@using StudioElf.Module.CRM.MeetingNotes.Services
@inherits CrmBase
@inject IMeetingNotesService MeetingNotesService

@* Dashboard widget — shows recent meetings across all contacts *@
<div class="card border shadow-sm h-100">
    <div class="card-header py-2">
        <h6 class="mb-0"><i class="bi bi-journal-text me-1"></i>Recent Meetings</h6>
    </div>
    <div class="card-body p-2">
        @if (_loading)
        {
            <small class="text-muted">Loading...</small>
        }
        else if (!_meetings.Any())
        {
            <small class="text-muted">No recent meetings.</small>
        }
        else
        {
            <div class="list-group list-group-flush">
                @foreach (var m in _meetings)
                {
                    <div class="list-group-item px-1 py-1 border-0 small">
                        <div class="fw-semibold">@m.Title</div>
                        <div class="text-muted" style="font-size:.72rem;">
                            @FormatLocalDate(m.MeetingDate, "MMM dd, yyyy")
                            @if (!string.IsNullOrEmpty(m.CreatedBy))
                            {
                                <span class="ms-1">· @m.CreatedBy</span>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private List<MeetingNoteDto> _meetings = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        try
        {
            _meetings = await MeetingNotesService.GetRecentAsync(ModuleState.ModuleId, PageState.User.Username, 5);
        }
        catch { _meetings = new(); }
        _loading = false;
    }
}
